# Database (usuário read-only — apenas SELECT no schema nexusgov)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexusgov_db
DB_USER=nexusgov_readonly
DB_PASSWORD=changeme

# Pool de conexões
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Ollama NUVEM — usado APENAS para o LLM (chat/síntese/router de tools)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=changeme
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_REQUEST_TIMEOUT=120.0

# Ollama LOCAL — usado APENAS para embeddings (bge-m3, pgvector)
OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_EMBED_API_KEY=
OLLAMA_EMBED_MODEL=bge-m3
EMBEDDING_DIM=1024

# MinIO / S3 — mesmo storage do nexusgov-api (anexos de contrato)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme
S3_BUCKET_GERAL=br.com.sofintech.nexusgov.geral

# Ingestão de documentos (poller em background)
INGEST_ENABLED=true
INGEST_POLL_SECONDS=30
INGEST_MAX_TENTATIVAS=3
CHUNK_MAX_CHARS=1500
CHUNK_MIN_CHARS=80
OCR_LANG=por

# Chat sobre documentos (RAG) — chunks são frases; top_k maior compensa contexto curto
DOC_CHAT_TOP_K=12

# JWT — tokens do Keycloak, mesmo realm do nexusgov-api (KEYCLOAK_ISSUER_URI lá).
# Assinatura assimétrica: a chave pública vem do JWKS do realm; não há secret aqui.
KEYCLOAK_ISSUER_URI=http://45.79.207.184:8082/realms/nexusgov
JWT_ALGORITHMS=RS256

# Sessões
SESSION_BACKEND=memory          # memory | redis
SESSION_MAX_SIZE=1000
SESSION_TTL_MINUTES=60
REDIS_URL=redis://localhost:6379/0

# CORS — lista CSV de origens permitidas. Vazio bloqueia tudo.
CORS_ORIGINS=http://localhost:5173

# Rate limit
RATE_LIMIT_PER_MINUTE=20

# Logging
SQL_ECHO=false

APP_PORT=8000
APP_HOST=0.0.0.0
APP_RELOAD=false

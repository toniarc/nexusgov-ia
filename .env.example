# Database (usuário read-only — apenas SELECT no schema nexusgov)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexusgov_db
DB_USER=nexusgov_readonly
DB_PASSWORD=changeme

# Pool de conexões
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Ollama
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=changeme
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_REQUEST_TIMEOUT=120.0

# Embeddings (HuggingFace, roda localmente)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# JWT — mesmo secret do nexusgov-api (base64-encoded)
JWT_SECRET=changeme
JWT_ALGORITHMS=HS384

# Sessões
SESSION_BACKEND=memory          # memory | redis
SESSION_MAX_SIZE=1000
SESSION_TTL_MINUTES=60
REDIS_URL=redis://localhost:6379/0

# CORS — lista CSV de origens permitidas. Vazio bloqueia tudo.
CORS_ORIGINS=http://localhost:5173

# Rate limit
RATE_LIMIT_PER_MINUTE=20

# Logging
SQL_ECHO=false

APP_PORT=8000
APP_HOST=0.0.0.0
APP_RELOAD=false
